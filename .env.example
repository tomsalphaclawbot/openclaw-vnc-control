# VNC Control — credential template
# Copy to .env and fill in your values.
# .env is gitignored and never committed.

# VNC target host (default: 127.0.0.1 for local self-control)
VNC_HOST=127.0.0.1

# VNC port (default: 5900)
VNC_PORT=5900

# macOS ARD password (Apple Remote Desktop / Screen Sharing password)
# Required for macOS targets — standard VNC password alone is not sufficient.
VNC_PASSWORD=your_vnc_password_here

# macOS ARD username (the macOS account name with Screen Sharing access)
# Required for macOS ARD auth. Leave blank for plain VNC targets.
VNC_USERNAME=your_macos_username_here

# Optional: path to Unix socket for daemon mode (default: /tmp/vnc-daemon.sock)
# VNC_SOCKET=/tmp/vnc-daemon.sock

# Optional: path to PID file for daemon mode (default: /tmp/vnc-daemon.pid)
# VNC_PIDFILE=/tmp/vnc-daemon.pid
